# Neon Postgres connection string
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Wallets — run `npm run generate-wallets` to create both.
# SELLER receives platform fees (Pro). BUYER is the treasury that pre-funds
# each citizen's custodial wallet — fund it at https://faucet.circle.com (Arc Testnet).
SELLER_ADDRESS=0xYourSellerAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey
BUYER_ADDRESS=0xYourBuyerAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# Session secret that envelopes the in-session wallet key — `openssl rand -hex 32`
PRAECO_SESSION_SECRET=your-32-byte-hex-secret

# Platform OpenAI key for the Reader-Agent and the Studio's AI co-writer
OPENAI_API_KEY=sk-...

# Optional overrides
# READER_FUND_USDC=0.2          # starter USDC per new citizen wallet
# PRAECO_LLM_MODEL=gpt-4o       # model for the agent + studio
# BASE_URL=http://localhost:3000
